// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  companies Company[] // Un utilisateur peut posséder plusieurs entreprises
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Company {
  id        String     @id @default(cuid())
  name      String
  owner     User       @relation(fields: [ownerId], references: [id])
  ownerId   String     // Clé étrangère vers User
  employees Employee[] // Une entreprise a plusieurs employés
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Employee {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  grossSalary Float
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String   // Clé étrangère vers Company
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
