// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

/// Rôle de l'utilisateur dans le système
/// - USER : Utilisateur standard avec accès à ses propres données
/// - ADMIN : Administrateur avec accès à la configuration des règles de cotisations
enum Role {
  USER
  ADMIN
}

model Utilisateur {
  id               String      @id @default(cuid())
  email            String      @unique
  nom              String?     @map("name")
  motDePasse       String      @map("password")
  role             Role        @default(USER) // Rôle de l'utilisateur (USER ou ADMIN)
  compagnies       Compagnie[] // Un utilisateur peut posséder plusieurs entreprises
  dateCreation     DateTime    @default(now()) @map("createdAt")
  dateModification DateTime    @updatedAt @map("updatedAt")

  @@map("User") // Conserve le nom de table existant pour compatibilité
}

model Compagnie {
  id                         String                   @id @default(cuid())
  nom                        String                   @map("name")
  proprietaire               Utilisateur              @relation(fields: [proprietaireId], references: [id])
  proprietaireId             String                   @map("ownerId") // Clé étrangère vers Utilisateur
  employes                   Employe[]                // Une entreprise a plusieurs employés
  integrationsComptables     AccountingIntegration[]  @map("accountingIntegrations") // Intégrations comptables (Sage, QuickBooks, etc.)
  dateCreation               DateTime                 @default(now()) @map("createdAt")
  dateModification           DateTime                 @updatedAt @map("updatedAt")

  @@map("Company") // Conserve le nom de table existant pour compatibilité
}

model Employe {
  id               String         @id @default(cuid())
  prenom           String         @map("firstName")
  nom              String         @map("lastName")
  email            String         @unique
  salaireBrut      Float          @map("grossSalary")
  departement      String?        @map("department") // Département de l'employé (optionnel)
  compagnie        Compagnie      @relation(fields: [compagnieId], references: [id])
  compagnieId      String         @map("companyId") // Clé étrangère vers Compagnie
  fichesPaie       FichePaie[]    // Un employé peut avoir plusieurs fiches de paie
  conges           Leave[]        @map("leaves") // Un employé peut avoir plusieurs congés
  soldesConges     LeaveBalance[] @map("leaveBalances") // Un employé peut avoir plusieurs soldes de congés (par type et année)
  frais            Expense[]      @map("expenses") // Un employé peut avoir plusieurs notes de frais (ancien modèle)
  rapportsFrais    ExpenseReport[] @map("expenseReports") // Un employé peut avoir plusieurs rapports de notes de frais
  dateCreation     DateTime       @default(now()) @map("createdAt")
  dateModification DateTime       @updatedAt @map("updatedAt")

  @@map("Employee") // Conserve le nom de table existant pour compatibilité
}

/// Fiche de paie d'un employé pour une période donnée
/// Renommé de Payslip vers FichePaie pour meilleure cohérence avec le français
/// La table garde le nom "Payslip" pour compatibilité avec les migrations existantes
model FichePaie {
  id                           String                      @id @default(cuid())
  periodeVersement             String                      @map("payPeriod") // Format: "2025-08" (année-mois)
  salaireBrut                  Float                       @map("grossSalary") // Salaire brut pour cette période
  prelevements                 Float                       @map("deductions") // Montant des cotisations sociales (legacy - à déprécier)
  salaireNet                   Float                       @map("netSalary") // Salaire net après déductions
  totalCotisationsSalariales   Float?                      // Total des cotisations salariales (nouveau système)
  totalCotisationsPatronales   Float?                      // Total des cotisations patronales (nouveau système)
  totalChargesFiscales         Float?                      // Total des charges fiscales (nouveau système)
  coutTotal                    Float?                      // Coût total employeur = brut + cotisations patronales
  employe                      Employe                     @relation(fields: [employeId], references: [id])
  employeId                    String                      @map("employeeId") // Clé étrangère vers Employe
  lignesCotisations            LigneCotisationFichePaie[]  // Détails ligne par ligne des cotisations
  dateCreation                 DateTime                    @default(now()) @map("createdAt")
  dateModification             DateTime                    @updatedAt @map("updatedAt")

  @@unique([employeId, periodeVersement]) // Un employé ne peut avoir qu'une fiche de paie par période
  @@map("Payslip") // Conserve le nom de table existant pour compatibilité
}

/// Ligne de détail d'une cotisation dans une fiche de paie
/// Stocke les informations détaillées de chaque cotisation appliquée
model LigneCotisationFichePaie {
  id                 String      @id @default(cuid())
  fichePaie          FichePaie   @relation(fields: [fichePaieId], references: [id], onDelete: Cascade)
  fichePaieId        String
  code               String      // Code de la règle de cotisation (ex: "SS_MALADIE_SAL")
  nom                String      // Nom de la cotisation (ex: "Assurance maladie")
  categorie          String      // Catégorie (ex: "Sécurité sociale")
  organisme          String      // Organisme collecteur (ex: "URSSAF")
  typeCotisation     String      // Type: COTISATION_SALARIALE, COTISATION_PATRONALE, CHARGE_FISCALE
  assiette           Float       // Assiette de calcul en euros
  taux               Float       // Taux appliqué (ex: 0.0755 pour 7,55%)
  montantSalarial    Float       // Montant de la part salariale (0 si patronale)
  montantPatronal    Float       // Montant de la part patronale (0 si salariale)
  montantTotal       Float       // Montant total de la ligne
  compteDebit        String?     // Compte comptable à débiter (optionnel)
  compteCredit       String?     // Compte comptable à créditer (optionnel)
  dateCreation       DateTime    @default(now()) @map("createdAt")
  dateModification   DateTime    @updatedAt @map("updatedAt")

  @@index([fichePaieId])
  @@map("lignes_cotisation_fiche_paie")
}

// ========== Enums pour les règles de cotisations ==========

/// Type de cotisation : définit qui supporte la charge
/// - COTISATION_SALARIALE : Déduite du salaire brut de l'employé (ex: CSG déductible)
/// - COTISATION_PATRONALE : Charge supportée par l'employeur (ex: cotisation famille)
/// - CHARGE_FISCALE : Taxes et impôts (ex: taxe d'apprentissage)
enum TypeCotisation {
  COTISATION_SALARIALE
  COTISATION_PATRONALE
  CHARGE_FISCALE
}

/// Type de calcul de la cotisation
/// - POURCENTAGE : Calcul basé sur un taux appliqué à l'assiette (le plus courant)
/// - MONTANT_FIXE : Montant fixe indépendant du salaire (ex: forfait social)
/// - TRANCHES : Calcul par tranches progressives (ex: certaines retraites complémentaires)
enum TypeCalcul {
  POURCENTAGE
  MONTANT_FIXE
  TRANCHES
}

/// Type d'assiette de calcul : base sur laquelle la cotisation est calculée
/// - SALAIRE_BRUT : Assiette = salaire brut total
/// - SALAIRE_NET : Assiette = salaire après déduction des cotisations salariales
/// - SALAIRE_PLAFONNE : Assiette limitée au Plafond Annuel de la Sécurité Sociale (PASS)
///   Le PASS est fixé annuellement (ex: 46 368€ en 2025, soit 3 864€/mois)
enum TypeAssiette {
  SALAIRE_BRUT
  SALAIRE_NET
  SALAIRE_PLAFONNE
}

// ========== Modèles pour les règles de cotisations ==========

/// Catégorie de cotisation : regroupe les règles par domaine
/// Exemples de codes standards :
/// - "SS" : Sécurité sociale (maladie, maternité, invalidité, décès)
/// - "RETRAITE" : Retraite de base et complémentaire
/// - "CHOMAGE" : Assurance chômage
/// - "AT_MP" : Accidents du travail et maladies professionnelles
/// - "FAMILLE" : Allocations familiales
/// - "CSG_CRDS" : Contribution sociale généralisée et CRDS
model CategorieCotisation {
  id          String             @id @default(cuid())
  code        String             @unique
  nom         String
  description String?
  regles      RegleCotisation[]
  dateCreation   DateTime           @default(now()) @map("createdAt")
  dateModification   DateTime           @updatedAt @map("updatedAt")

  @@map("categories_cotisation")
}

/// Organisme collecteur : entité qui collecte les cotisations
/// Exemples de codes standards :
/// - "URSSAF" : Union de recouvrement des cotisations de sécurité sociale et d'allocations familiales
/// - "AGIRC_ARRCO" : Association générale des institutions de retraite des cadres -
///                    Association pour le régime de retraite complémentaire des salariés
/// - "POLE_EMPLOI" : Service public de l'emploi (assurance chômage)
/// - "CPAM" : Caisse primaire d'assurance maladie
/// - "CARSAT" : Caisse d'assurance retraite et de la santé au travail
model OrganismeCotisation {
  id          String             @id @default(cuid())
  code        String             @unique
  nom         String
  description String?
  regles      RegleCotisation[]
  dateCreation   DateTime           @default(now()) @map("createdAt")
  dateModification   DateTime           @updatedAt @map("updatedAt")

  @@map("organismes_cotisation")
}

/// Règle de cotisation : définit une cotisation sociale ou charge fiscale spécifique
/// Chaque règle combine :
/// - Une catégorie (domaine) et un organisme collecteur
/// - Un type de cotisation (salariale/patronale/fiscale)
/// - Un mode de calcul et une assiette
/// - Des limites optionnelles (plancher/plafond en euros)
///
/// Exemples de codes :
/// - "SS_MALADIE_SAL" : Cotisation maladie salariale
/// - "SS_MALADIE_PAT" : Cotisation maladie patronale
/// - "RETRAITE_BASE_SAL" : Retraite de base salariale (plafonnée)
/// - "RETRAITE_BASE_PAT" : Retraite de base patronale
/// - "CSG_DEDUCTIBLE" : CSG déductible (98,25% de la CSG totale)
model RegleCotisation {
  id                String               @id @default(cuid())
  code              String               @unique
  nom               String
  description       String?
  categorie         CategorieCotisation  @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  categorieId       String
  organisme         OrganismeCotisation  @relation(fields: [organismeId], references: [id], onDelete: Cascade)
  organismeId       String
  typeCotisation    TypeCotisation
  typeCalcul        TypeCalcul
  typeAssiette      TypeAssiette
  plancher          Float?               // Montant minimum en euros (ex: 0 pour pas de plancher)
  plafond           Float?               // Montant maximum en euros (ex: PASS mensuel = 3864€)
  taux              TauxCotisation[]
  reglesComptables  RegleComptable[]
  estActif          Boolean              @default(true)
  dateCreation         DateTime             @default(now()) @map("createdAt")
  dateModification         DateTime             @updatedAt @map("updatedAt")

  @@map("regles_cotisation")
}

/// Taux de cotisation avec historique législatif
/// Permet de suivre l'évolution des taux dans le temps pour conformité réglementaire.
///
/// Format du taux : valeur décimale (ex: 0.0755 = 7,55%)
///
/// Période de validité :
/// - dateDebut : Date de début d'application (inclusive)
/// - dateFin : Date de fin d'application (exclusive). Si NULL, le taux est toujours actif.
///
/// IMPORTANT : L'application doit s'assurer qu'il n'y a pas de chevauchement de périodes
/// pour une même règle. La contrainte unique sur (regleId, dateDebut) empêche d'avoir
/// deux taux avec la même date de début, mais ne garantit pas l'absence de chevauchement.
/// La logique métier doit valider que dateDebut du nouveau taux >= dateFin du taux précédent.
model TauxCotisation {
  id        String          @id @default(cuid())
  regle     RegleCotisation @relation(fields: [regleId], references: [id], onDelete: Cascade)
  regleId   String
  taux      Float
  dateDebut DateTime
  dateFin   DateTime?
  dateCreation DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@unique([regleId, dateDebut])
  @@index([regleId, dateDebut])
  @@map("taux_cotisation")
}

/// Règle comptable associée à une cotisation
/// Définit l'écriture comptable générée lors du calcul de la paie.
///
/// Plan comptable français (PCG) - Exemples de comptes :
/// - Comptes de charges (débit) :
///   * 6411 : Salaires bruts
///   * 6451 : Cotisations sociales à la charge de l'employeur
///   * 6311 : Taxes sur salaires
/// - Comptes de dettes (crédit) :
///   * 421 : Personnel - rémunérations dues
///   * 431 : Sécurité sociale
///   * 437 : Autres organismes sociaux (retraite complémentaire, etc.)
///   * 4386 : Organismes sociaux - autres charges à payer
model RegleComptable {
  id           String          @id @default(cuid())
  regle        RegleCotisation @relation(fields: [regleId], references: [id], onDelete: Cascade)
  regleId      String
  compteDebit  String          // Ex: "6451" (Cotisations à la charge de l'employeur)
  compteCredit String          // Ex: "431" (Sécurité sociale)
  description  String?
  dateCreation    DateTime        @default(now()) @map("createdAt")
  dateModification    DateTime        @updatedAt @map("updatedAt")

  @@map("regles_comptables")
}

// ========== Modèles pour les analytics RH ==========

/// Statut d'une demande de congé
enum LeaveStatus {
  PENDING    // En attente de validation
  APPROVED   // Approuvé
  REJECTED   // Rejeté
  CANCELLED  // Annulé
}

/// Type de congé
enum LeaveType {
  PAID_LEAVE       // Congés payés
  SICK_LEAVE       // Arrêt maladie
  UNPAID_LEAVE     // Congé sans solde
  PARENTAL_LEAVE   // Congé parental
  OTHER            // Autre
}

/// Congé d'un employé
model Leave {
  id               String      @id @default(cuid())
  employe          Employe     @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String      @map("employeeId")
  typeDemande      LeaveType   @map("type")
  statut           LeaveStatus @default(PENDING) @map("status")
  dateDebut        DateTime    @map("startDate") // Date de début du congé
  dateFin          DateTime    @map("endDate") // Date de fin du congé
  nombreJours      Float       @map("days") // Nombre de jours de congé (peut être 0.5 pour une demi-journée)
  motif            String?     @map("reason") // Raison du congé (optionnel)
  dateCreation     DateTime    @default(now()) @map("createdAt")
  dateModification DateTime    @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([dateDebut, dateFin])
  @@map("leaves")
}

/// Solde de congés d'un employé
/// Suit le nombre de jours de congés disponibles pour chaque type de congé
model LeaveBalance {
  id               String    @id @default(cuid())
  employe          Employe   @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String    @map("employeeId")
  typeDemande      LeaveType @map("type")
  annee            Int       @map("year") // Année du solde (ex: 2025)
  joursTotal       Float     @map("totalDays") // Nombre total de jours acquis (ex: 25 jours pour congés payés)
  joursUtilises    Float     @default(0) @map("usedDays") // Nombre de jours utilisés
  joursRestants    Float     @map("remainingDays") // Jours restants = totalDays - usedDays
  dateCreation     DateTime  @default(now()) @map("createdAt")
  dateModification DateTime  @updatedAt @map("updatedAt")

  @@unique([employeId, typeDemande, annee]) // Un employé a un seul solde par type de congé et par année
  @@index([employeId])
  @@map("leave_balances")
}

/// Statut d'une note de frais
enum ExpenseStatus {
  PENDING    // En attente de validation
  APPROVED   // Approuvé
  REJECTED   // Rejeté
  PAID       // Payé
}

/// Catégorie de note de frais
enum ExpenseCategory {
  TRANSPORT      // Transport (train, avion, taxi, etc.)
  MEAL           // Repas
  ACCOMMODATION  // Hébergement
  EQUIPMENT      // Équipement
  OTHER          // Autre
}

/// Note de frais d'un employé (ancien modèle - déprécié)
/// Utilisez ExpenseReport et ExpenseItem pour les nouveaux développements
model Expense {
  id               String          @id @default(cuid())
  employe          Employe         @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String          @map("employeeId")
  categorie        ExpenseCategory @map("category")
  statut           ExpenseStatus   @default(PENDING) @map("status")
  montant          Float           @map("amount") // Montant en euros
  date             DateTime        // Date de la dépense
  description      String          // Description de la dépense
  dateCreation     DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([date])
  @@map("expenses")
}

/// Rapport de notes de frais (multi-lignes)
/// Un rapport regroupe plusieurs dépenses d'un employé pour une période
model ExpenseReport {
  id               String        @id @default(cuid())
  employe          Employe       @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String        @map("employeeId")
  titre            String        @map("title") // Titre du rapport (ex: "Déplacement Paris - Mars 2025")
  statut           ExpenseStatus @default(PENDING) @map("status")
  montantTotal     Float         @default(0) @map("totalAmount") // Montant total calculé à partir des lignes
  lignes           ExpenseItem[] @map("items") // Lignes de dépenses du rapport
  dateCreation     DateTime      @default(now()) @map("createdAt")
  dateModification DateTime      @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([statut])
  @@map("expense_reports")
}

/// Ligne de dépense dans un rapport de notes de frais
/// Chaque ligne représente une dépense individuelle avec son justificatif
model ExpenseItem {
  id               String          @id @default(cuid())
  rapport          ExpenseReport   @relation(fields: [rapportId], references: [id], onDelete: Cascade) @map("report")
  rapportId        String          @map("reportId")
  categorie        ExpenseCategory @map("category")
  montant          Float           @map("amount") // Montant en euros
  date             DateTime        // Date de la dépense
  description      String          // Description de la dépense
  cheminRecu       String?         @map("receiptPath") // Chemin du fichier de reçu (PDF, JPG, PNG)
  dateCreation     DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@index([rapportId])
  @@index([date])
  @@map("expense_items")
}

// ========== Modèles pour les intégrations comptables ==========

/// Type d'intégration comptable
enum AccountingIntegrationType {
  SAGE       // Sage (formats TRA/PNM)
  QUICKBOOKS // QuickBooks Online
}

/// Statut d'une intégration comptable
enum AccountingIntegrationStatus {
  ACTIVE     // Active et fonctionnelle
  INACTIVE   // Désactivée
  ERROR      // En erreur
}

/// Intégration comptable d'une entreprise
/// Permet l'export automatique des données de paie vers un logiciel comptable
model AccountingIntegration {
  id                   String                       @id @default(cuid())
  compagnie            Compagnie                    @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId          String                       @map("companyId")
  typeIntegration      AccountingIntegrationType    @map("type")
  statut               AccountingIntegrationStatus  @default(INACTIVE) @map("status")
  configuration        String                       // JSON avec la configuration spécifique (mapping comptes, credentials OAuth, etc.)
  dateDerniereSynchro  DateTime?                    @map("lastSyncAt") // Date du dernier export réussi
  derniereErreur       String?                      @map("lastError") // Dernier message d'erreur (si status = ERROR)
  journauxExport       AccountingExportLog[]        @map("exportLogs") // Historique des exports
  dateCreation         DateTime                     @default(now()) @map("createdAt")
  dateModification     DateTime                     @updatedAt @map("updatedAt")

  @@unique([compagnieId, typeIntegration]) // Une entreprise ne peut avoir qu'une seule intégration de chaque type
  @@map("accounting_integrations")
}

/// Statut d'un export comptable
enum ExportStatus {
  PENDING    // En attente
  SUCCESS    // Réussi
  FAILED     // Échoué
  RETRYING   // Nouvelle tentative en cours
}

/// Log d'export comptable
/// Conserve l'historique de tous les exports vers les logiciels comptables
model AccountingExportLog {
  id                      String                 @id @default(cuid())
  integration             AccountingIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  integrationId           String
  statut                  ExportStatus           @default(PENDING) @map("status")
  periodeVersement        String?                @map("payPeriod") // Période de paie exportée (format: "2025-08")
  nombreEnregistrements   Int                    @default(0) @map("recordCount") // Nombre d'écritures exportées
  cheminFichier           String?                @map("filePath") // Chemin du fichier généré (pour Sage)
  messageErreur           String?                @map("errorMessage") // Message d'erreur (si status = FAILED)
  nombreTentatives        Int                    @default(0) @map("retryCount") // Nombre de tentatives
  dateCreation            DateTime               @default(now()) @map("createdAt")
  dateModification        DateTime               @updatedAt @map("updatedAt")

  @@index([integrationId])
  @@index([statut])
  @@map("accounting_export_logs")
}
