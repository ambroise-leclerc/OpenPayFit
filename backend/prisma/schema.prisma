// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

/// Rôle de l'utilisateur dans le système
/// - USER : Utilisateur standard avec accès à ses propres données
/// - ADMIN : Administrateur avec accès à la configuration des règles de cotisations
enum Role {
  USER
  ADMIN
}

model Utilisateur {
  id               String      @id @default(cuid())
  email            String      @unique
  nom              String?     @map("name")
  motDePasse       String      @map("password")
  role             Role        @default(USER) // Rôle de l'utilisateur (USER ou ADMIN)
  compagnies       Compagnie[] // Un utilisateur peut posséder plusieurs entreprises
  versionsDSN      DSNVersion[] // Versions de DSN créées par cet utilisateur
  dateCreation     DateTime    @default(now()) @map("createdAt")
  dateModification DateTime    @updatedAt @map("updatedAt")

  @@map("User") // Conserve le nom de table existant pour compatibilité
}

model Compagnie {
  id                         String                   @id @default(cuid())
  nom                        String                   @map("name")
  proprietaire               Utilisateur              @relation(fields: [proprietaireId], references: [id])
  proprietaireId             String                   @map("ownerId") // Clé étrangère vers Utilisateur

  // Informations légales et administratives (pour DSN)
  // Note: SIRET n'a pas de contrainte @unique car nullable. La validation d'unicité
  // se fait au niveau applicatif pour les SIRET non-null uniquement.
  siret                      String?                  // Numéro SIRET (14 chiffres) - identifiant unique de l'établissement
  codeNaf                    String?                  // Code NAF/APE (5 caractères) - activité principale
  adresse                    String?                  // Adresse complète de l'établissement
  codePostal                 String?                  // Code postal
  ville                      String?                  // Ville
  conventionCollective       String?                  // Code IDCC de la convention collective appliquée
  numeroUrssaf               String?                  // Numéro d'adhérent URSSAF

  // Relations
  employes                   Employe[]                      // Une entreprise a plusieurs employés
  organismesSpecifiques      OrganismeCotisation[]          // Organismes collecteurs spécifiques à cette entreprise (caisses de retraite de branche, mutuelles, etc.)
  integrationsComptables     AccountingIntegration[]        // Intégrations comptables (Sage, QuickBooks, etc.)
  declarationsDSN            DSNDeclaration[]               // Déclarations sociales nominatives générées
  evenementsDSN              DSNEvent[]                     // Événements DSN (embauches, fins de contrat, etc.)
  configurationNetEntreprises ConfigurationNetEntreprises? // Configuration pour la transmission automatique DSN

  dateCreation               DateTime                 @default(now()) @map("createdAt")
  dateModification           DateTime                 @updatedAt @map("updatedAt")

  @@map("Company") // Conserve le nom de table existant pour compatibilité
}

model Employe {
  id               String         @id @default(cuid())
  prenom           String         @map("firstName")
  nom              String         @map("lastName")
  email            String         @unique
  salaireBrut      Float          @map("grossSalary")
  departement      String?        @map("department") // Département de l'employé (optionnel)

  // Informations personnelles (pour DSN)
  numeroSecuriteSociale  String?  @unique // Numéro de sécurité sociale (15 chiffres)
  dateNaissance          DateTime? // Date de naissance
  lieuNaissance          String?  // Lieu de naissance (ville et pays)
  nationalite            String?  // Nationalité (code ISO pays sur 2 lettres, ex: "FR")

  // Informations contractuelles (pour DSN)
  typeContrat            TypeContrat? // Type de contrat de travail
  dateEmbauche           DateTime?    // Date d'embauche dans l'entreprise
  dateFinContrat         DateTime?    // Date de fin de contrat (pour CDD, intérim, etc.)
  numeroMatricule        String?      // Numéro de matricule interne de l'employé
  poste                  String?      // Intitulé du poste occupé
  qualification          String?      // Qualification professionnelle ou coefficient

  // Statut professionnel (pour calcul des cotisations par tranches)
  statutEmploye          StatutEmploye @default(NON_CADRE) // Statut pour le calcul des cotisations

  // Relations
  compagnie        Compagnie      @relation(fields: [compagnieId], references: [id])
  compagnieId      String         @map("companyId") // Clé étrangère vers Compagnie
  fichesPaie       FichePaie[]    // Un employé peut avoir plusieurs fiches de paie
  conges           Leave[]        // Un employé peut avoir plusieurs congés
  soldesConges     LeaveBalance[] // Un employé peut avoir plusieurs soldes de congés (par type et année)
  frais            Expense[]      // Un employé peut avoir plusieurs notes de frais (ancien modèle)
  rapportsFrais    ExpenseReport[] // Un employé peut avoir plusieurs rapports de notes de frais
  evenementsDSN    DSNEvent[]     // Un employé peut avoir plusieurs événements DSN
  dateCreation     DateTime       @default(now()) @map("createdAt")
  dateModification DateTime       @updatedAt @map("updatedAt")

  @@map("Employee") // Conserve le nom de table existant pour compatibilité
}

/// Fiche de paie d'un employé pour une période donnée
/// Renommé de Payslip vers FichePaie pour meilleure cohérence avec le français
/// La table garde le nom "Payslip" pour compatibilité avec les migrations existantes
model FichePaie {
  id                           String                      @id @default(cuid())
  periodeVersement             String                      @map("payPeriod") // Format: "2025-08" (année-mois)
  salaireBrut                  Float                       @map("grossSalary") // Salaire brut pour cette période
  prelevements                 Float                       @map("deductions") // Montant des cotisations sociales (legacy - à déprécier)
  salaireNet                   Float                       @map("netSalary") // Salaire net après déductions
  totalCotisationsSalariales   Float?                      // Total des cotisations salariales (nouveau système)
  totalCotisationsPatronales   Float?                      // Total des cotisations patronales (nouveau système)
  totalChargesFiscales         Float?                      // Total des charges fiscales (nouveau système)
  coutTotal                    Float?                      // Coût total employeur = brut + cotisations patronales
  employe                      Employe                     @relation(fields: [employeId], references: [id])
  employeId                    String                      @map("employeeId") // Clé étrangère vers Employe
  lignesCotisations            LigneCotisationFichePaie[]  // Détails ligne par ligne des cotisations
  dateCreation                 DateTime                    @default(now()) @map("createdAt")
  dateModification             DateTime                    @updatedAt @map("updatedAt")

  @@unique([employeId, periodeVersement]) // Un employé ne peut avoir qu'une fiche de paie par période
  @@map("Payslip") // Conserve le nom de table existant pour compatibilité
}

/// Ligne de détail d'une cotisation dans une fiche de paie
/// Stocke les informations détaillées de chaque cotisation appliquée
model LigneCotisationFichePaie {
  id                 String      @id @default(cuid())
  fichePaie          FichePaie   @relation(fields: [fichePaieId], references: [id], onDelete: Cascade)
  fichePaieId        String
  code               String      // Code de la règle de cotisation (ex: "SS_MALADIE_SAL")
  nom                String      // Nom de la cotisation (ex: "Assurance maladie")
  categorie          String      // Catégorie (ex: "Sécurité sociale")
  organisme          String      // Organisme collecteur (ex: "URSSAF")
  typeCotisation     String      // Type: COTISATION_SALARIALE, COTISATION_PATRONALE, CHARGE_FISCALE
  assiette           Float       // Assiette de calcul en euros
  taux               Float       // Taux appliqué (ex: 0.0755 pour 7,55%)
  montantSalarial    Float       // Montant de la part salariale (0 si patronale)
  montantPatronal    Float       // Montant de la part patronale (0 si salariale)
  montantTotal       Float       // Montant total de la ligne
  compteDebit        String?     // Compte comptable à débiter (optionnel)
  compteCredit       String?     // Compte comptable à créditer (optionnel)
  dateCreation       DateTime    @default(now()) @map("createdAt")
  dateModification   DateTime    @updatedAt @map("updatedAt")

  @@index([fichePaieId])
  @@map("lignes_cotisation_fiche_paie")
}

// ========== Enums pour les employés ==========

/// Type de contrat de travail
enum TypeContrat {
  CDI                   // Contrat à durée indéterminée
  CDD                   // Contrat à durée déterminée
  INTERIM               // Contrat de travail temporaire
  APPRENTISSAGE         // Contrat d'apprentissage
  PROFESSIONNALISATION  // Contrat de professionnalisation
  STAGE                 // Convention de stage
}

/// Statut professionnel de l'employé (pour calcul des cotisations)
/// Détermine quelles tranches de cotisations s'appliquent
enum StatutEmploye {
  NON_CADRE              // Employé, technicien, agent de maîtrise
  CADRE                  // Cadre
  CADRE_DIRIGEANT        // Cadre dirigeant (exonération de certaines cotisations)
  FORFAIT_JOURS          // Cadre au forfait jours (régime spécifique)
}

// ========== Enums pour les règles de cotisations ==========

/// Type de cotisation : définit qui supporte la charge
/// - COTISATION_SALARIALE : Déduite du salaire brut de l'employé (ex: CSG déductible)
/// - COTISATION_PATRONALE : Charge supportée par l'employeur (ex: cotisation famille)
/// - CHARGE_FISCALE : Taxes et impôts (ex: taxe d'apprentissage)
enum TypeCotisation {
  COTISATION_SALARIALE
  COTISATION_PATRONALE
  CHARGE_FISCALE
}

/// Type de calcul de la cotisation
/// - POURCENTAGE : Calcul basé sur un taux appliqué à l'assiette (le plus courant)
/// - MONTANT_FIXE : Montant fixe indépendant du salaire (ex: forfait social)
/// - TRANCHES : Calcul par tranches progressives (ex: certaines retraites complémentaires)
enum TypeCalcul {
  POURCENTAGE
  MONTANT_FIXE
  TRANCHES
}

/// Type d'assiette de calcul : base sur laquelle la cotisation est calculée
/// - SALAIRE_BRUT : Assiette = salaire brut total
/// - SALAIRE_NET : Assiette = salaire après déduction des cotisations salariales
/// - SALAIRE_PLAFONNE : Assiette limitée au Plafond Annuel de la Sécurité Sociale (PASS)
///   Le PASS est fixé annuellement (ex: 46 368€ en 2025, soit 3 864€/mois)
enum TypeAssiette {
  SALAIRE_BRUT
  SALAIRE_NET
  SALAIRE_PLAFONNE
}

// ========== Modèles pour les règles de cotisations ==========

/// Catégorie de cotisation : regroupe les règles par domaine
/// Exemples de codes standards :
/// - "SS" : Sécurité sociale (maladie, maternité, invalidité, décès)
/// - "RETRAITE" : Retraite de base et complémentaire
/// - "CHOMAGE" : Assurance chômage
/// - "AT_MP" : Accidents du travail et maladies professionnelles
/// - "FAMILLE" : Allocations familiales
/// - "CSG_CRDS" : Contribution sociale généralisée et CRDS
model CategorieCotisation {
  id          String             @id @default(cuid())
  code        String             @unique
  nom         String
  description String?
  regles      RegleCotisation[]
  dateCreation   DateTime           @default(now()) @map("createdAt")
  dateModification   DateTime           @updatedAt @map("updatedAt")

  @@map("categories_cotisation")
}

/// Type d'organisme collecteur
enum TypeOrganisme {
  URSSAF              // URSSAF (Sécurité sociale générale)
  RETRAITE            // Caisse de retraite complémentaire (AGIRC-ARRCO, etc.)
  CHOMAGE             // Pôle Emploi (assurance chômage)
  PREVOYANCE          // Institution de prévoyance
  MUTUELLE            // Mutuelle santé obligatoire
  FORMATION           // OPCO (Opérateur de compétences)
  AUTRE               // Autre organisme
}

/// Organisme collecteur : entité qui collecte les cotisations
/// Deux types d'organismes :
/// - Globaux (estGlobal = true) : Obligatoires pour toutes les entreprises (URSSAF, Pôle Emploi, AGIRC-ARRCO)
/// - Spécifiques (estGlobal = false) : Liés à une entreprise particulière (caisses de retraite spécifiques, mutuelles de branche, etc.)
///
/// Exemples de codes standards pour les organismes globaux :
/// - "URSSAF" : Union de recouvrement des cotisations de sécurité sociale et d'allocations familiales
/// - "AGIRC_ARRCO" : Association générale des institutions de retraite des cadres -
///                    Association pour le régime de retraite complémentaire des salariés
/// - "POLE_EMPLOI" : Service public de l'emploi (assurance chômage)
model OrganismeCotisation {
  id               String              @id @default(cuid())
  code             String              @unique
  nom              String
  typeOrganisme    TypeOrganisme       // Type d'organisme (URSSAF, RETRAITE, etc.)
  description      String?
  estGlobal        Boolean             @default(false) // true = obligatoire pour toutes les entreprises, false = spécifique à une entreprise

  // Informations de contact (optionnelles)
  adresse          String?
  codePostal       String?
  ville            String?
  telephone        String?
  email            String?
  siteWeb          String?

  // Identification (optionnel)
  numeroSiret      String?             // Numéro SIRET de l'organisme

  // Relation vers l'entreprise (uniquement pour les organismes spécifiques)
  compagnie        Compagnie?          @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId      String?

  // Relations
  regles           RegleCotisation[]

  dateCreation     DateTime            @default(now()) @map("createdAt")
  dateModification DateTime            @updatedAt @map("updatedAt")

  @@index([compagnieId])
  @@index([estGlobal])
  @@map("organismes_cotisation")
}

/// Règle de cotisation : définit une cotisation sociale ou charge fiscale spécifique
/// Chaque règle combine :
/// - Une catégorie (domaine) et un organisme collecteur
/// - Un type de cotisation (salariale/patronale/fiscale)
/// - Un mode de calcul et une assiette
/// - Des limites optionnelles (plancher/plafond en euros)
///
/// Exemples de codes :
/// - "SS_MALADIE_SAL" : Cotisation maladie salariale
/// - "SS_MALADIE_PAT" : Cotisation maladie patronale
/// - "RETRAITE_BASE_SAL" : Retraite de base salariale (plafonnée)
/// - "RETRAITE_BASE_PAT" : Retraite de base patronale
/// - "CSG_DEDUCTIBLE" : CSG déductible (98,25% de la CSG totale)
model RegleCotisation {
  id                String               @id @default(cuid())
  code              String               @unique
  nom               String
  description       String?
  categorie         CategorieCotisation  @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  categorieId       String
  organisme         OrganismeCotisation  @relation(fields: [organismeId], references: [id], onDelete: Cascade)
  organismeId       String
  typeCotisation    TypeCotisation
  typeCalcul        TypeCalcul
  typeAssiette      TypeAssiette
  plancher          Float?               // Montant minimum en euros (ex: 0 pour pas de plancher)
  plafond           Float?               // Montant maximum en euros (ex: PASS mensuel = 3864€)
  taux              TauxCotisation[]
  tranches          TrancheCotisation[]  // Tranches pour calcul progressif (si typeCalcul = TRANCHES)
  reglesComptables  RegleComptable[]
  estActif          Boolean              @default(true)
  dateCreation         DateTime             @default(now()) @map("createdAt")
  dateModification         DateTime             @updatedAt @map("updatedAt")

  @@map("regles_cotisation")
}

/// Taux de cotisation avec historique législatif
/// Permet de suivre l'évolution des taux dans le temps pour conformité réglementaire.
///
/// Format du taux : valeur décimale (ex: 0.0755 = 7,55%)
///
/// Période de validité :
/// - dateDebut : Date de début d'application (inclusive)
/// - dateFin : Date de fin d'application (exclusive). Si NULL, le taux est toujours actif.
///
/// IMPORTANT : L'application doit s'assurer qu'il n'y a pas de chevauchement de périodes
/// pour une même règle. La contrainte unique sur (regleId, dateDebut) empêche d'avoir
/// deux taux avec la même date de début, mais ne garantit pas l'absence de chevauchement.
/// La logique métier doit valider que dateDebut du nouveau taux >= dateFin du taux précédent.
model TauxCotisation {
  id        String          @id @default(cuid())
  regle     RegleCotisation @relation(fields: [regleId], references: [id], onDelete: Cascade)
  regleId   String
  taux      Float
  dateDebut DateTime
  dateFin   DateTime?
  dateCreation DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@unique([regleId, dateDebut])
  @@index([regleId, dateDebut])
  @@map("taux_cotisation")
}

/// Tranche de cotisation pour les calculs par tranches progressives
/// Définit une tranche de salaire avec son taux spécifique
/// Les tranches sont basées sur le PASS (Plafond Annuel de la Sécurité Sociale)
///
/// Système de tranches français standard :
/// - Tranche 1 : 0 à 1 PASS - salaires jusqu'à 46 368€/an (3 864€/mois en 2025)
/// - Tranche 2 : 1 à 8 PASS - salaires de 46 368€ à 370 944€/an
/// - Tranche 3 : Au-delà de 8 PASS - salaires supérieurs à 370 944€/an
model TrancheCotisation {
  id              String           @id @default(cuid())
  regle           RegleCotisation  @relation(fields: [regleId], references: [id], onDelete: Cascade)
  regleId         String

  // Définition de la tranche
  numeroTranche   Int              // Numéro de la tranche (1, 2, 3, etc.)
  nomTranche      String           // Nom de la tranche (ex: "Tranche 1", "Tranche A")

  // Bornes de la tranche (en multiples du PASS)
  // Ex: pour Tranche 1 : borneInferieure=0, borneSuperieure=1
  // Ex: pour Tranche 2 : borneInferieure=1, borneSuperieure=8
  // Ex: pour Tranche 3 : borneInferieure=8, borneSuperieure=null (sans limite)
  borneInferieure Float            // Multiple du PASS (0, 1, 8, etc.)
  borneSuperieure Float?           // Multiple du PASS (null = pas de limite supérieure)

  // Taux de cotisation pour cette tranche
  tauxSalarial    Float            @default(0) // Taux part salariale (ex: 0.0340 = 3,40%)
  tauxPatronal    Float            @default(0) // Taux part patronale (ex: 0.0460 = 4,60%)

  // Statuts d'employés concernés par cette tranche
  // Certaines tranches ne s'appliquent qu'aux cadres
  appliqueCadre       Boolean      @default(true)
  appliqueNonCadre    Boolean      @default(true)
  appliqueDirigeant   Boolean      @default(false)

  // Période de validité
  dateDebut       DateTime
  dateFin         DateTime?

  dateCreation    DateTime         @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@unique([regleId, numeroTranche, dateDebut])
  @@index([regleId, dateDebut])
  @@map("tranches_cotisation")
}

/// Règle comptable associée à une cotisation
/// Définit l'écriture comptable générée lors du calcul de la paie.
///
/// Plan comptable français (PCG) - Exemples de comptes :
/// - Comptes de charges (débit) :
///   * 6411 : Salaires bruts
///   * 6451 : Cotisations sociales à la charge de l'employeur
///   * 6311 : Taxes sur salaires
/// - Comptes de dettes (crédit) :
///   * 421 : Personnel - rémunérations dues
///   * 431 : Sécurité sociale
///   * 437 : Autres organismes sociaux (retraite complémentaire, etc.)
///   * 4386 : Organismes sociaux - autres charges à payer
model RegleComptable {
  id           String          @id @default(cuid())
  regle        RegleCotisation @relation(fields: [regleId], references: [id], onDelete: Cascade)
  regleId      String
  compteDebit  String          // Ex: "6451" (Cotisations à la charge de l'employeur)
  compteCredit String          // Ex: "431" (Sécurité sociale)
  description  String?
  dateCreation    DateTime        @default(now()) @map("createdAt")
  dateModification    DateTime        @updatedAt @map("updatedAt")

  @@map("regles_comptables")
}

// ========== Modèles pour les analytics RH ==========

/// Statut d'une demande de congé
enum LeaveStatus {
  PENDING    // En attente de validation
  APPROVED   // Approuvé
  REJECTED   // Rejeté
  CANCELLED  // Annulé
}

/// Type de congé
enum LeaveType {
  PAID_LEAVE       // Congés payés
  SICK_LEAVE       // Arrêt maladie
  UNPAID_LEAVE     // Congé sans solde
  PARENTAL_LEAVE   // Congé parental
  OTHER            // Autre
}

/// Congé d'un employé
model Leave {
  id               String      @id @default(cuid())
  employe          Employe     @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String      @map("employeeId")
  typeDemande      LeaveType   @map("type")
  statut           LeaveStatus @default(PENDING) @map("status")
  dateDebut        DateTime    @map("startDate") // Date de début du congé
  dateFin          DateTime    @map("endDate") // Date de fin du congé
  nombreJours      Float       @map("days") // Nombre de jours de congé (peut être 0.5 pour une demi-journée)
  motif            String?     @map("reason") // Raison du congé (optionnel)
  dateCreation     DateTime    @default(now()) @map("createdAt")
  dateModification DateTime    @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([dateDebut, dateFin])
  @@map("leaves")
}

/// Solde de congés d'un employé
/// Suit le nombre de jours de congés disponibles pour chaque type de congé
model LeaveBalance {
  id               String    @id @default(cuid())
  employe          Employe   @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String    @map("employeeId")
  typeDemande      LeaveType @map("type")
  annee            Int       @map("year") // Année du solde (ex: 2025)
  joursTotal       Float     @map("totalDays") // Nombre total de jours acquis (ex: 25 jours pour congés payés)
  joursUtilises    Float     @default(0) @map("usedDays") // Nombre de jours utilisés
  joursRestants    Float     @map("remainingDays") // Jours restants = totalDays - usedDays
  dateCreation     DateTime  @default(now()) @map("createdAt")
  dateModification DateTime  @updatedAt @map("updatedAt")

  @@unique([employeId, typeDemande, annee]) // Un employé a un seul solde par type de congé et par année
  @@index([employeId])
  @@map("leave_balances")
}

/// Statut d'une note de frais
enum ExpenseStatus {
  PENDING    // En attente de validation
  APPROVED   // Approuvé
  REJECTED   // Rejeté
  PAID       // Payé
}

/// Catégorie de note de frais
enum ExpenseCategory {
  TRANSPORT      // Transport (train, avion, taxi, etc.)
  MEAL           // Repas
  ACCOMMODATION  // Hébergement
  EQUIPMENT      // Équipement
  OTHER          // Autre
}

/// Note de frais d'un employé (ancien modèle - déprécié)
/// Utilisez ExpenseReport et ExpenseItem pour les nouveaux développements
model Expense {
  id               String          @id @default(cuid())
  employe          Employe         @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String          @map("employeeId")
  categorie        ExpenseCategory @map("category")
  statut           ExpenseStatus   @default(PENDING) @map("status")
  montant          Float           @map("amount") // Montant en euros
  date             DateTime        // Date de la dépense
  description      String          // Description de la dépense
  dateCreation     DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([date])
  @@map("expenses")
}

/// Rapport de notes de frais (multi-lignes)
/// Un rapport regroupe plusieurs dépenses d'un employé pour une période
model ExpenseReport {
  id               String        @id @default(cuid())
  employe          Employe       @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId        String        @map("employeeId")
  titre            String        @map("title") // Titre du rapport (ex: "Déplacement Paris - Mars 2025")
  statut           ExpenseStatus @default(PENDING) @map("status")
  montantTotal     Float         @default(0) @map("totalAmount") // Montant total calculé à partir des lignes
  lignes           ExpenseItem[] // Lignes de dépenses du rapport
  dateCreation     DateTime      @default(now()) @map("createdAt")
  dateModification DateTime      @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([statut])
  @@map("expense_reports")
}

/// Ligne de dépense dans un rapport de notes de frais
/// Chaque ligne représente une dépense individuelle avec son justificatif
model ExpenseItem {
  id               String          @id @default(cuid())
  rapport          ExpenseReport   @relation(fields: [rapportId], references: [id], onDelete: Cascade)
  rapportId        String          @map("reportId")
  categorie        ExpenseCategory @map("category")
  montant          Float           @map("amount") // Montant en euros
  date             DateTime        // Date de la dépense
  description      String          // Description de la dépense
  cheminRecu       String?         @map("receiptPath") // Chemin du fichier de reçu (PDF, JPG, PNG)
  dateCreation     DateTime        @default(now()) @map("createdAt")
  dateModification DateTime        @updatedAt @map("updatedAt")

  @@index([rapportId])
  @@index([date])
  @@map("expense_items")
}

// ========== Modèles pour les intégrations comptables ==========

/// Type d'intégration comptable
enum AccountingIntegrationType {
  SAGE       // Sage (formats TRA/PNM)
  QUICKBOOKS // QuickBooks Online
}

/// Statut d'une intégration comptable
enum AccountingIntegrationStatus {
  ACTIVE     // Active et fonctionnelle
  INACTIVE   // Désactivée
  ERROR      // En erreur
}

/// Intégration comptable d'une entreprise
/// Permet l'export automatique des données de paie vers un logiciel comptable
model AccountingIntegration {
  id                   String                       @id @default(cuid())
  compagnie            Compagnie                    @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId          String                       @map("companyId")
  typeIntegration      AccountingIntegrationType    @map("type")
  statut               AccountingIntegrationStatus  @default(INACTIVE) @map("status")
  configuration        String                       // JSON avec la configuration spécifique (mapping comptes, credentials OAuth, etc.)
  dateDerniereSynchro  DateTime?                    @map("lastSyncAt") // Date du dernier export réussi
  derniereErreur       String?                      @map("lastError") // Dernier message d'erreur (si status = ERROR)
  journauxExport       AccountingExportLog[]        // Historique des exports
  dateCreation         DateTime                     @default(now()) @map("createdAt")
  dateModification     DateTime                     @updatedAt @map("updatedAt")

  @@unique([compagnieId, typeIntegration]) // Une entreprise ne peut avoir qu'une seule intégration de chaque type
  @@map("accounting_integrations")
}

/// Statut d'un export comptable
enum ExportStatus {
  PENDING    // En attente
  SUCCESS    // Réussi
  FAILED     // Échoué
  RETRYING   // Nouvelle tentative en cours
}

/// Log d'export comptable
/// Conserve l'historique de tous les exports vers les logiciels comptables
model AccountingExportLog {
  id                      String                 @id @default(cuid())
  integration             AccountingIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  integrationId           String
  statut                  ExportStatus           @default(PENDING) @map("status")
  periodeVersement        String?                @map("payPeriod") // Période de paie exportée (format: "2025-08")
  nombreEnregistrements   Int                    @default(0) @map("recordCount") // Nombre d'écritures exportées
  cheminFichier           String?                @map("filePath") // Chemin du fichier généré (pour Sage)
  messageErreur           String?                @map("errorMessage") // Message d'erreur (si status = FAILED)
  nombreTentatives        Int                    @default(0) @map("retryCount") // Nombre de tentatives
  dateCreation            DateTime               @default(now()) @map("createdAt")
  dateModification        DateTime               @updatedAt @map("updatedAt")

  @@index([integrationId])
  @@index([statut])
  @@map("accounting_export_logs")
}

// ========== Modèles pour la DSN (Déclaration Sociale Nominative) ==========

/// Type de déclaration DSN
enum TypeDeclarationDSN {
  MENSUELLE       // Déclaration mensuelle normale
  EVENEMENTIELLE  // Déclaration événementielle (ex: fin de contrat, arrêt maladie)
}

/// Statut d'une déclaration DSN
enum StatutDSN {
  BROUILLON   // En cours de préparation
  VALIDEE     // Validée et prête à être transmise
  TRANSMISE   // Transmise aux organismes sociaux
  ERREUR      // Erreur lors de la génération ou transmission
}

/// Déclaration Sociale Nominative (DSN)
/// Stocke l'historique des déclarations DSN générées pour une entreprise
/// La DSN est une déclaration mensuelle obligatoire qui transmet aux organismes sociaux
/// l'ensemble des données issues de la paie (salaires, cotisations, etc.)
model DSNDeclaration {
  id                    String              @id @default(cuid())
  compagnie             Compagnie           @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId           String              @map("companyId")

  // Informations de la déclaration
  periodeDeclaration    String              // Format "YYYY-MM" - mois de paie concerné (ex: "2025-03")
  typeDeclaration       TypeDeclarationDSN  @default(MENSUELLE) // Type de déclaration (mensuelle ou événementielle)
  statut                StatutDSN           @default(BROUILLON) // Statut de la déclaration

  // Contenu et métadonnées
  contenuXml            String?             // Contenu XML de la DSN au format NORME 4DS (peut être volumineux)
  messagesValidation    String?             // Messages de validation (JSON) - erreurs, avertissements, informations
  numeroDeclaration     String?             // Numéro unique attribué par le système (ex: "DSN-2025-03-001")

  // Dates importantes
  dateGeneration        DateTime?           // Date de génération du fichier XML
  dateTransmission      DateTime?           // Date de transmission effective aux organismes

  dateCreation          DateTime            @default(now()) @map("createdAt")
  dateModification      DateTime            @updatedAt @map("updatedAt")

  @@unique([compagnieId, periodeDeclaration, typeDeclaration]) // Une seule déclaration par entreprise, période et type
  @@index([compagnieId])
  @@index([statut])
  @@index([periodeDeclaration])
  @@map("dsn_declarations")

  // Relations
  transmissions    TransmissionDSN[] // Historique des transmissions de cette DSN
  evenements       DSNEvent[]        // Événements DSN inclus dans cette déclaration
  versions         DSNVersion[]      // Historique des versions de cette DSN
}

// ========== Modèles pour la transmission automatique DSN via net-entreprises.fr ==========

/// Statut d'une transmission DSN
enum StatutTransmission {
  EN_ATTENTE       // En attente d'envoi
  EN_COURS         // Transmission en cours
  TRANSMISE        // Transmise avec succès
  ACCUSE_RECEPTION // Accusé de réception reçu
  ERREUR           // Erreur lors de la transmission
  REJETEE          // Rejetée par net-entreprises.fr
}

/// Transmission DSN vers net-entreprises.fr
/// Stocke l'historique des transmissions automatiques via l'API EDI Machine-to-Machine
model TransmissionDSN {
  id                    String              @id @default(cuid())
  declaration           DSNDeclaration      @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  declarationId         String

  // Statut de la transmission
  statut                StatutTransmission  @default(EN_ATTENTE)

  // Dates importantes
  dateTransmission      DateTime?           // Date d'envoi effectif
  dateAccuseReception   DateTime?           // Date de réception de l'AR
  dateDerniereVerification DateTime?        // Date de dernière vérification du statut

  // Identifiants et références
  idTransmission        String?             // ID de transaction retourné par net-entreprises.fr
  numeroProtocole       String?             // Numéro de protocole EDI

  // Accusé de réception et retours
  accuse                String?             // Contenu XML de l'accusé de réception (peut être volumineux)
  codeRetour            String?             // Code retour (ex: "00" = succès, "01" = erreur, etc.)
  messagesRetour        String?             // Messages de retour (JSON) - erreurs, avertissements

  // Gestion des erreurs et retry
  nombreTentatives      Int                 @default(0) // Nombre de tentatives de transmission
  derniereErreur        String?             // Dernier message d'erreur rencontré
  prochaineTentative    DateTime?           // Date de la prochaine tentative (pour retry automatique)

  dateCreation          DateTime            @default(now()) @map("createdAt")
  dateModification      DateTime            @updatedAt @map("updatedAt")

  @@index([declarationId])
  @@index([statut])
  @@index([dateTransmission])
  @@map("transmissions_dsn")
}

/// Configuration Net-Entreprises pour une entreprise
/// Stocke les informations d'authentification et de configuration pour l'API EDI
model ConfigurationNetEntreprises {
  id                    String    @id @default(cuid())
  compagnie             Compagnie @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId           String    @unique // Une seule configuration par entreprise

  // Identifiants Net-Entreprises
  siretDeclarant        String    // SIRET du déclarant (peut différer du SIRET de l'établissement)
  numeroAdhesion        String?   // Numéro d'adhésion Net-Entreprises

  // Configuration de l'authentification
  typeCertificat        String    @default("PEM") // Type de certificat (PEM, PKCS12, etc.)
  certificat            String?   // Certificat client (encodé en base64 pour sécurité)
  clePrivee             String?   // Clé privée (encodée en base64, chiffrée)
  motDePasseCertificat  String?   // Mot de passe du certificat (chiffré)

  // Configuration EDI
  urlApi                String    @default("https://www.net-entreprises.fr/api/dsn") // URL de l'API
  modeTest              Boolean   @default(true) // Mode test/sandbox ou production

  // Statut et validation
  estActif              Boolean   @default(false) // Configuration active ou non
  derniereVerification  DateTime? // Date de dernière vérification de la validité
  derniereErreur        String?   // Dernière erreur de configuration

  dateCreation          DateTime  @default(now()) @map("createdAt")
  dateModification      DateTime  @updatedAt @map("updatedAt")

  @@map("configurations_net_entreprises")
}

// ========== Modèles pour les événements DSN ==========

/// Type d'événement DSN
/// Codes standard pour les déclarations événementielles
enum TypeEvenementDSN {
  EMBAUCHE              // Code 005 - Embauche d'un salarié
  FIN_CONTRAT           // Code 010 - Fin de contrat de travail
  ARRET_MALADIE         // Code 020 - Arrêt maladie
  CONGE_MATERNITE       // Congé maternité
  CONGE_PATERNITE       // Congé paternité
  CHANGEMENT_CONTRAT    // Changement dans le contrat (modification salaire, temps de travail, etc.)
  AUTRE                 // Autre événement DSN
}

/// Statut d'un événement DSN
enum StatutEvenementDSN {
  BROUILLON   // En cours de saisie, non validé
  VALIDE      // Validé, prêt à être déclaré
  DECLARE     // Déclaré via DSN événementielle
  ERREUR      // Erreur lors de la déclaration
}

/// Événement DSN - Événements RH à déclarer en temps réel
/// Stocke les événements de ressources humaines qui nécessitent une DSN événementielle
/// conformément à la norme DSN (embauche, fin de contrat, arrêt maladie, etc.)
model DSNEvent {
  id                    String              @id @default(cuid())
  employe               Employe             @relation(fields: [employeId], references: [id], onDelete: Cascade)
  employeId             String
  compagnie             Compagnie           @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  compagnieId           String

  // Type et statut
  typeEvenement         TypeEvenementDSN    // Type d'événement (embauche, fin de contrat, etc.)
  statut                StatutEvenementDSN  @default(BROUILLON)

  // Dates
  dateEvenement         DateTime            // Date effective de l'événement
  dateDeclaration       DateTime?           // Date de déclaration DSN (si déjà déclaré)

  // Informations spécifiques à l'événement
  donneesSpecifiques    String?             // Données spécifiques selon le type (JSON)
                                            // Ex pour FIN_CONTRAT: {"motif": "demission", "dernierJourTravaille": "2025-03-31"}
                                            // Ex pour ARRET_MALADIE: {"dateDebut": "2025-03-15", "dateFin": "2025-03-25"}

  // Motif et commentaires
  motif                 String?             // Motif de l'événement (ex: démission, licenciement, fin de CDD)
  commentaires          String?             // Commentaires libres pour usage interne

  // Relation vers la déclaration DSN (si déjà transmise)
  declaration           DSNDeclaration?     @relation(fields: [declarationId], references: [id])
  declarationId         String?

  dateCreation          DateTime            @default(now()) @map("createdAt")
  dateModification      DateTime            @updatedAt @map("updatedAt")

  @@index([employeId])
  @@index([compagnieId])
  @@index([typeEvenement])
  @@index([statut])
  @@index([dateEvenement])
  @@map("dsn_events")
}

// ========== Modèles pour l'historique des versions DSN ==========

/// Type de modification apportée à une DSN
enum TypeModificationDSN {
  CREATION         // Création initiale de la DSN
  MODIFICATION     // Modification du contenu
  REGENERATION     // Régénération complète de la DSN
  RESTAURATION     // Restauration d'une version antérieure
}

/// Version d'une DSN - Historique des modifications
/// Stocke toutes les versions successives d'une déclaration DSN pour traçabilité et audit
/// Chaque modification (création, mise à jour, régénération) crée une nouvelle version
model DSNVersion {
  id                    String                @id @default(cuid())
  declaration           DSNDeclaration        @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  declarationId         String

  // Informations de versioning
  numeroVersion         Int                   // Numéro de version séquentiel (1, 2, 3, etc.)
  typeModification      TypeModificationDSN   @default(MODIFICATION) // Type de modification

  // Snapshot complet de la version
  contenuXml            String?               // Contenu XML de la DSN à cette version (snapshot complet)
  messagesValidation    String?               // Messages de validation (JSON) à cette version
  statut                StatutDSN             // Statut de la DSN à cette version

  // Métadonnées de la modification
  auteur                Utilisateur           @relation(fields: [auteurId], references: [id])
  auteurId              String                // Utilisateur ayant créé cette version
  commentaire           String?               // Commentaire décrivant la modification

  // Dates
  dateCreation          DateTime              @default(now()) @map("createdAt") // Date de création de cette version

  @@unique([declarationId, numeroVersion]) // Une seule version N par déclaration
  @@index([declarationId])
  @@index([auteurId])
  @@index([dateCreation])
  @@map("dsn_versions")
}
