// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  companies Company[] // Un utilisateur peut posséder plusieurs entreprises
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Company {
  id        String     @id @default(cuid())
  name      String
  owner     User       @relation(fields: [ownerId], references: [id])
  ownerId   String     // Clé étrangère vers User
  employees Employee[] // Une entreprise a plusieurs employés
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Employee {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String    @unique
  baseHourlyRate Float     @default(0) // Taux horaire de base
  company        Company   @relation(fields: [companyId], references: [id])
  companyId      String // Clé étrangère vers Company
  payslips       Payslip[] // Un employé a plusieurs fiches de paie
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Payslip {
  id                  String   @id @default(cuid())
  periodStartDate     DateTime
  periodEndDate       DateTime
  normalHoursWorked   Float
  overtimeHoursWorked Float
  grossSalary         Float
  netSalary           Float
  totalContributions  Float
  employee            Employee @relation(fields: [employeeId], references: [id])
  employeeId          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
